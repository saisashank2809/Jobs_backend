{'Id': '30777', 'Title': 'Facilities/Maintenance Technician', 'Category': 'Property and Facilities', 'RequisitionType': 'Hourly', 'JobGrade': None, 'RequisitionId': 300001310603746, 'ExternalPostedStartDate': '2026-03-11T17:03:34+00:00', 'JobLevel': None, 'JobSchedule': 'Full time', 'JobShift': 'Day', 'StudyLevel': 'High School Graduate', 'InternationalTravelRequired': None, 'ExternalContactName': None, 'ExternalContactEmail': None, 'ContractType': 'Regular', 'ExternalPostedEndDate': None, 'JobFamilyId': 300000008724326, 'GeographyId': 300000003278670, 'GeographyNodeId': 100001178078749, 'ExternalDescriptionStr': '<p class="MsoNormal" style="mso-layout-grid-align:none;text-autospace:none;"><span style="color:black;">Ensure general building maintenance and building renovations.</span></p>', 'CorporateDescriptionStr': '', 'OrganizationDescriptionStr': '', 'ShortDescriptionStr': 'Ensure general building maintenance and building renovations.', 'ContentLocale': 'en', 'PrimaryLocation': 'Tahlequah, OK, United States', 'PrimaryLocationCountry': 'US', 'ObjectVerNumberProfile': None, 'ApplyWhenNotPostedFlag': None, 'ExternalQualificationsStr': '<ul><li>High School Diploma and four (4) years of directly related experience or an equivalent combination of education and experience.</li><li>Minimum three (3) years of drywall and related maintenance trades experience preferred.</li><li>Certification from a vocational, technical and/or business school preferred.</li><li>Knowledge of necessary tools, including power tools.</li><li>Good mechanical, mathematical, and carpentry skills.</li><li>Must have a valid driver’s license.</li></ul><p>&nbsp;</p><p style="text-autospace:none;"><span><strong><u>NOTE: this job is a safety sensitive position subject to drug testing requirements.&nbsp; A positive drug test will result in a job offer being rescinded or, for active employees, termination, even if they test positive for marijuana and have a valid medical marijuana license.</u></strong></span></p>', 'InternalQualificationsStr': '<ul><li>High School Diploma and four (4) years of directly related experience or an equivalent combination of education and experience.</li><li>Minimum three (3) years of drywall and related maintenance trades experience preferred.</li><li>Certification from a vocational, technical and/or business school preferred.</li><li>Knowledge of necessary tools, including power tools.</li><li>Good mechanical, mathematical, and carpentry skills.</li><li>Must have a valid driver’s license.</li></ul><p>&nbsp;</p><p style="text-autospace:none;"><span><strong><u>NOTE: this job is a safety sensitive position subject to drug testing requirements.&nbsp; A positive drug test will result in a job offer being rescinded or, for active employees, termination, even if they test positive for marijuana and have a valid medical marijuana license.</u></strong></span></p>', 'InternalResponsibilitiesStr': '<ul><li>Perform preventive maintenance following policies and procedures.</li><li>Inspect various building renovations.</li><li>Oversee removal of existing walls and reframing.</li><li>Perform routine maintenance including, but not limited to, sheetrock and ceiling repair, minor plumbing problems, interior and exterior painting, replacing damaged wall coverings and tile, changing lights and fixtures, installing or repairing locks, laying carpet, commercial and ceramic tile, hanging pictures/art throughout the facilities, and any other general facility maintenance related duties.</li><li>Operate tractors and forklifts, as needed.</li><li>Manage multiple projects without having direct supervisory responsibilities.</li><li>Work is performed in a variety of settings, including, climate-controlled office settings and/or outdoors in all types of weather.</li><li>Work will include lifting and adjusting heavy objects and will come in contact with sharp, hot and/or very cold supplies and equipment.</li><li>Employee will be required to wear proper personal protective equipment and maintain safety procedures at all times.</li><li>Employee may be called into work outside of normal work hours or work long hours for emergency maintenance and repair situations.</li><li>Perform other job-related duties as assigned.</li></ul>', 'ExternalResponsibilitiesStr': '<ul><li>Perform preventive maintenance following policies and procedures.</li><li>Inspect various building renovations.</li><li>Oversee removal of existing walls and reframing.</li><li>Perform routine maintenance including, but not limited to, sheetrock and ceiling repair, minor plumbing problems, interior and exterior painting, replacing damaged wall coverings and tile, changing lights and fixtures, installing or repairing locks, laying carpet, commercial and ceramic tile, hanging pictures/art throughout the facilities, and any other general facility maintenance related duties.</li><li>Operate tractors and forklifts, as needed.</li><li>Manage multiple projects without having direct supervisory responsibilities.</li><li>Work is performed in a variety of settings, including, climate-controlled office settings and/or outdoors in all types of weather.</li><li>Work will include lifting and adjusting heavy objects and will come in contact with sharp, hot and/or very cold supplies and equipment.</li><li>Employee will be required to wear proper personal protective equipment and maintain safety procedures at all times.</li><li>Employee may be called into work outside of normal work hours or work long hours for emergency maintenance and repair situations.</li><li>Perform other job-related duties as assigned.</li></ul>', 'JobFunctionCode': '503', 'HotJobFlag': False, 'TrendingFlag': False, 'BeFirstToApplyFlag': False, 'WorkplaceTypeCode': 'ORA_ON_SITE', 'WorkplaceType': 'On-site', 'OtherRequisitionTitle': None, 'NumberOfOpenings': None, 'HiringManager': None, 'Organization': None, 'BusinessUnitId': 300000003239009, 'LegalEmployerId': 300000003237435, 'OrganizationId': 300000003239009,